{
  "name": "parampara",
  "version": "1.0.0",
  "description": "A community-driven digital archive for rural cultural heritage preservation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "ws": "node server/websocket/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run ws\"",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "heritage",
    "culture",
    "rural",
    "preservation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "archiver": "^8.0.0",
    "body-parser": "^1.20.2",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "helmet": "^8.2.0",
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.4"
  }
}